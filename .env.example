# BidFlow Platform - Environment Variables
# Copy this file to .env and fill in the values

# ===========================================
# APPLICATION
# ===========================================
NODE_ENV=development
LOG_LEVEL=debug
PORT=3000

# ===========================================
# DATABASE
# ===========================================
POSTGRES_USER=bidflow
POSTGRES_PASSWORD=bidflow_dev_password_change_in_prod
POSTGRES_DB=bidflow
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ===========================================
# REDIS
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# ===========================================
# RABBITMQ
# ===========================================
RABBITMQ_USER=bidflow
RABBITMQ_PASSWORD=bidflow_dev_password_change_in_prod
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@${RABBITMQ_HOST}:${RABBITMQ_PORT}

# ===========================================
# JWT AUTH
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===========================================
# CORS
# ===========================================
CORS_ORIGIN=http://localhost:3001
CORS_CREDENTIALS=true

# ===========================================
# TENANT
# ===========================================
TENANT_RESOLUTION_STRATEGY=subdomain
DEFAULT_TENANT_SLUG=public

# ===========================================
# AI SERVICE
# ===========================================
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_API_KEY=

# ===========================================
# EXTERNAL SERVICES
# ===========================================
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@bidflow.com

# ===========================================
# S3 / STORAGE
# ===========================================
S3_BUCKET=bidflow-dev
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ===========================================
# LOGGING
# ===========================================
LOG_FORMAT=json
LOG_DESTINATION=stdout

# ===========================================
# METRICS
# ===========================================
METRICS_ENABLED=true
METRICS_PORT=9090

# ===========================================
# FEATURE FLAGS
# ===========================================
FF_AI_ANALYSIS=enabled
FF_WORKFLOW_AUTOMATION=enabled
FF_BILLING_SELF_SERVICE=enabled