{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "com.bidflow.bidding.bid.placed.v1",
  "title": "BidPlacedEvent",
  "description": "Um lance foi registrado em uma disputa eletrônica",
  "type": "object",
  "properties": {
    "specversion": { "type": "string", "const": "1.0" },
    "id": { "type": "string", "format": "uuid", "description": "ID único do evento" },
    "source": { "type": "string", "format": "uri", "description": "Origem do evento" },
    "type": { "type": "string", "const": "com.bidflow.bidding.bid.placed.v1" },
    "subject": { "type": "string", "description": "ID do auction" },
    "time": { "type": "string", "format": "date-time", "description": "Timestamp ISO 8601" },
    "datacontenttype": { "type": "string", "const": "application/json" },
    "tenantid": { "type": "string", "format": "uuid" },
    "userid": { "type": "string", "format": "uuid" },
    "data": {
      "type": "object",
      "properties": {
        "bidId": { "type": "string", "format": "uuid" },
        "auctionId": { "type": "string", "format": "uuid" },
        "rfpId": { "type": "string", "format": "uuid" },
        "userId": { "type": "string", "format": "uuid" },
        "userName": { "type": "string" },
        "amount": { "type": "string", "pattern": "^[0-9]+\\.[0-9]{2}$" },
        "currency": { "type": "string", "enum": ["BRL", "USD", "EUR"] },
        "previousPrice": { "type": "string", "pattern": "^[0-9]+\\.[0-9]{2}$" },
        "isAutomatic": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" },
        "round": { "type": "integer", "minimum": 1 }
      },
      "required": ["bidId", "auctionId", "userId", "amount", "timestamp"]
    }
  },
  "required": ["specversion", "id", "source", "type", "time", "datacontenttype", "tenantid", "data"]
}
