{
  "name": "bidflow-platform",
  "version": "1.0.0",
  "private": true,
  "description": "BidFlow Platform - Enterprise Monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "turbo run db:generate",
    "db:push": "turbo run db:push",
    "db:migrate": "turbo run db:migrate",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.0",
    "prettier": "^3.1.0",
    "ts-loader": "^9.5.7",
    "turbo": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "packageManager": "npm@9.6.0",
  "turbo": {
    "pipeline": {
      "build": {
        "dependsOn": [
          "^build"
        ],
        "outputs": [
          "dist/**",
          ".next/**",
          "build/**"
        ]
      },
      "dev": {
        "cache": false,
        "persistent": true
      },
      "lint": {
        "outputs": []
      },
      "test": {
        "dependsOn": [
          "build"
        ],
        "outputs": [
          "coverage/**"
        ]
      },
      "db:generate": {
        "cache": false
      },
      "db:push": {
        "cache": false
      },
      "db:migrate": {
        "cache": false
      },
      "clean": {
        "cache": false
      }
    }
  },
  "dependencies": {
    "ts-node": "^10.9.2"
  }
}
